# Copie para .env antes de: docker compose up -d --build
# cp .env.docker.example .env

# --- Ollama ---
# No mesmo servidor que o Docker: host.docker.internal
# Em outra máquina na rede: http://IP_OU_HOST:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3

# --- Streamlit (porta distinta do assistente RAG em 8501) ---
STREAMLIT_PORT=8502
STREAMLIT_PUBLIC_URL=http://Srv0312sr:8502

# --- Pasta opcional de requerimentos no host (para aba "Pasta no servidor") ---
# Windows Server com unidade mapeada:
#   REQUERIMENTOS_HOST_PATH=Z:\Requerimentos
# Linux com mount CIFS:
#   REQUERIMENTOS_HOST_PATH=/mnt/codevasf/Requerimentos
REQUERIMENTOS_HOST_PATH=./data
