# Backend de IA: auto | ollama | hf | zerogpu
LLM_BACKEND=auto

# Ollama — uso local / intranet
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:1b.2:1b

# Hugging Face Inference Providers (pago / créditos mensais)
# HF_TOKEN=hf_xxx
# HF_MODEL=Qwen/Qwen2.5-7B-Instruct

# ZeroGPU no Space (gratuito — padrão no HF Spaces)
# LLM_BACKEND=zerogpu
# ZEROGPU_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Pasta com as Listas de Documentos (PDFs de checklist)
CHECKLISTS_PATH=./checklists

# Pasta temporária para uploads e extração de ZIP
UPLOADS_PATH=./data/uploads

# URL pública no servidor interno (atalhos / documentação)
# STREAMLIT_PUBLIC_URL=http://Srv0312sr:8502

